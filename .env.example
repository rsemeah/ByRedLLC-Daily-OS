# Copy to `.env.local` and fill in values (never commit `.env.local`).
# Run `pnpm verify:env` to check required keys.

# -----------------------------------------------------------------------------
# Access control — required. Hard allowlist for the internal OS at
# app.byredllc.com. Comma-separated, case-insensitive. Anyone outside this
# list who logs in gets redirected to /auth/error?code=not_authorized.
# -----------------------------------------------------------------------------
BYRED_INTERNAL_EMAILS=clashon64@gmail.com,rorysemeah@icloud.com,paradise8733@yahoo.com,g.homira@gmail.com

# Canonical origin for auth redirects (password reset links, OAuth callbacks).
# Prod: https://app.byredllc.com — Dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase — required for auth, RLS, and app data
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: seed script (`pnpm seed:users`), admin scripts, schema discovery.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# -----------------------------------------------------------------------------
# Monday.com — optional; enables push/pull, webhooks, /integrations/monday boards list
# -----------------------------------------------------------------------------
# GraphQL token (Personal API Token or OAuth token — server only).
MONDAY_API_KEY=

# Alternative name supported by code if you prefer not to use MONDAY_API_KEY:
# MONDAY_TOKEN=

# Board ID for create_item / default sync target (omit to use built-in default in code).
MONDAY_BOARD_ID=

# Required for NEW-task creation via Monday webhook/sync. When unset, webhook + board pull
# update existing linked tasks only; unknown Monday items are skipped (no tenant → no insert).
# Value must match a row in `byred_tenants.id` (e.g. `t1` for "By Red LLC").
MONDAY_SYNC_TENANT_ID=

# Optional: pin a group when creating items; otherwise first group on the board is used.
MONDAY_GROUP_ID=

# Verifies inbound webhook requests (Bearer or x-monday-webhook-token).
MONDAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AI — optional; AI Actions on tasks and daily brief generation
# -----------------------------------------------------------------------------
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Cron / internal API — optional; protects /api/cron/daily-brief and /api/sync/monday
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Seed script (`pnpm seed:users`) — required only when running that script
# -----------------------------------------------------------------------------
BYRED_KP_EMAIL=
BYRED_RORY_EMAIL=
